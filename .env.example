# uniprot-link configuration (copy to .env). All variables are optional.

# --- UniProt SPARQL endpoint ---
# UniProt asks programmatic clients to provide a contact email in the User-Agent.
UNIPROT_LINK_SPARQL__CONTACT_EMAIL=bernt.popp@charite.de
# UNIPROT_LINK_SPARQL__BASE_URL=https://sparql.uniprot.org/sparql
# UNIPROT_LINK_SPARQL__TIMEOUT=30
# UNIPROT_LINK_SPARQL__RATE_LIMIT_PER_SECOND=3.0
# UNIPROT_LINK_SPARQL__DEFAULT_LIMIT=50
# UNIPROT_LINK_SPARQL__MAX_LIMIT=10000

# --- Server ---
# UNIPROT_LINK_TRANSPORT=unified      # unified | http | stdio
# UNIPROT_LINK_HOST=127.0.0.1
# UNIPROT_LINK_PORT=8000
# UNIPROT_LINK_MCP_PATH=/mcp

# --- Logging ---
# UNIPROT_LINK_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR | CRITICAL
# UNIPROT_LINK_LOG_FORMAT=console     # console | json
